<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Home - Project10A</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        body {
            background: url('https://images.unsplash.com/photo-1550745165-9bc0b252726f?q=80&w=2070&auto=format&fit=crop') no-repeat center center fixed;
            background-size: cover;
        }
        .glass {
            background: rgba(0, 0, 0, 0.85);
            backdrop-filter: blur(25px);
            -webkit-backdrop-filter: blur(25px);
            border: 1px solid rgba(255, 255, 255, 0.05);
        }
    </style>
</head>
<body class="min-h-screen flex items-center justify-center font-sans text-white">

<div class="glass p-10 rounded-[2rem] shadow-2xl max-w-3xl w-full mx-4">

    <!-- GRID LAYOUT -->
    <div class="grid grid-cols-3 gap-4 items-center text-center">

        <!-- Top Row -->
        <div class="p-4 rounded-2xl bg-white/5 border border-white/5 hover:bg-white/10 transition-all">
            <p class="text-[10px] text-blue-400 font-black uppercase tracking-widest mb-1">Security</p>
            <p class="text-xs text-slate-200">JWT Protected</p>
        </div>

        <div></div>

        <div class="p-4 rounded-2xl bg-white/5 border border-white/5 hover:bg-white/10 transition-all">
            <p class="text-[10px] text-emerald-400 font-black uppercase tracking-widest mb-1">Access</p>
            <p class="text-xs text-slate-200">Admin Control</p>
        </div>

        <!-- Middle Row -->
        <div></div>

        <!-- CENTER MAIN TITLE -->
        <div>
            <h1 class="text-5xl font-extrabold tracking-tight drop-shadow-lg">Project10A</h1>
            <p class="text-slate-300 text-sm mt-2">Secure Access System</p>

        
        </div>

        <div></div>

        <!-- Bottom Row -->
        <div class="p-4 rounded-2xl bg-white/5 border border-white/5 hover:bg-white/10 transition-all">
            <p class="text-[10px] text-purple-400 font-black uppercase tracking-widest mb-1">Audit</p>
            <p class="text-xs text-slate-200">Activity Logs</p>
        </div>

        <div></div>

        <div class="p-4 rounded-2xl bg-white/5 border border-white/5 hover:bg-white/10 transition-all">
            <p class="text-[10px] text-amber-400 font-black uppercase tracking-widest mb-1">Recovery</p>
            <p class="text-xs text-slate-200">Encrypted Q&A</p>
        </div>

    </div>

    <!-- Buttons -->
    <div class="flex flex-col gap-4 mt-10">
            <a href="/auth/login" class="bg-blue-600 hover:bg-blue-500 text-center transition-all py-3 rounded-xl font-semibold shadow-lg">
                Login to Account
            </a>
            <a href="/auth/register" class="bg-white/10 hover:bg-white/20 text-center transition-all py-3 rounded-xl font-semibold border border-white/10">
                Create New Account
            </a>
      
    </div>

    <!-- Footer -->
   

</div>

</body>
</html>