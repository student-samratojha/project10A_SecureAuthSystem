<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login - Project10A</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        body {
            background: url('https://images.unsplash.com/photo-1550745165-9bc0b252726f?q=80&w=2070&auto=format&fit=crop') no-repeat center center fixed;
            background-size: cover;
        }
        .glass {
            background: rgba(0, 0, 0, 0.85);
            backdrop-filter: blur(25px);
            -webkit-backdrop-filter: blur(25px);
            border: 1px solid rgba(255, 255, 255, 0.05);
        }
    </style>
</head>
<body class="min-h-screen flex items-center justify-center font-sans text-white">
    <div class="glass p-12 rounded-[2rem] shadow-2xl text-center max-w-lg w-full mx-4">
        <h1 class="text-4xl font-bold mb-6 tracking-tight">Login to Project10A</h1>
        <p class="text-slate-300 mb-8 text-lg">Access your secure account</p>

        <% if (typeof error !== 'undefined' && error) { %>
            <p class="text-red-400 mb-4"><%= error %></p>
        <% } %>
        <% if (typeof success !== 'undefined' && success) { %>
            <p class="text-green-400 mb-4"><%= success %></p>
        <% } %>

        <form action="/auth/login" method="POST" class="flex flex-col gap-4">
            <input type="email" name="email" placeholder="Email" required
                   class="p-3 rounded-lg bg-white/10 border border-white/20 focus:outline-none focus:ring-2 focus:ring-blue-500 text-white placeholder-slate-400">
            <input type="password" name="password" placeholder="Password" required
                   class="p-3 rounded-lg bg-white/10 border border-white/20 focus:outline-none focus:ring-2 focus:ring-blue-500 text-white placeholder-slate-400">
            <button type="submit"
                    class="bg-blue-600 hover:bg-blue-500 transition-all py-3 rounded-xl font-semibold shadow-lg shadow-blue-900/20 mt-4">
                Login
            </button>
            <a href="/auth/forget-password" 
               class="text-center bg-white/5 hover:bg-white/10 transition-all py-3 rounded-xl font-semibold border border-white/10 text-slate-300">
                Forgot Password?
            </a>
        </form>

        <div class="mt-6 text-sm">
            <a href="/auth/register" class="text-blue-400 hover:underline">Don't have an account? Register Now</a>
        </div>
    </div>
</body>
</html>