<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Set New Password - Project10A</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        body {
            background: url('https://images.unsplash.com/photo-1550745165-9bc0b252726f?q=80&w=2070&auto=format&fit=crop') no-repeat center center fixed;
            background-size: cover;
        }
        .glass {
            background: rgba(0, 0, 0, 0.85);
            backdrop-filter: blur(25px);
            -webkit-backdrop-filter: blur(25px);
            border: 1px solid rgba(255, 255, 255, 0.05);
        }
    </style>
</head>
<body class="min-h-screen flex items-center justify-center font-sans text-white">
    <div class="glass p-12 rounded-[2rem] shadow-2xl text-center max-w-lg w-full mx-4">
        <h1 class="text-4xl font-bold mb-6 tracking-tight">New Password</h1>
        <p class="text-slate-300 mb-8 text-lg">Set a strong password for <%= email %></p>

        <form action="/auth/reset-password/<%= email %>" method="POST" class="flex flex-col gap-4">
            <input type="password" name="newPassword" placeholder="Enter New Password" required
                   class="p-3 rounded-lg bg-white/10 border border-white/20 focus:outline-none focus:ring-2 focus:ring-blue-500 text-white placeholder-slate-400">
            <button type="submit"
                    class="bg-emerald-600 hover:bg-emerald-500 transition-all py-3 rounded-xl font-semibold shadow-lg shadow-emerald-900/20 mt-4">
                Update Password
            </button>
        </form>
    </div>
</body>
</html>