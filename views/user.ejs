<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>User Dashboard - Project10A</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        body {
            background: url('https://images.unsplash.com/photo-1550745165-9bc0b252726f?q=80&w=2070&auto=format&fit=crop') no-repeat center center fixed;
            background-size: cover;
        }
        .glass {
            background: rgba(0, 0, 0, 0.85);
            backdrop-filter: blur(25px);
            -webkit-backdrop-filter: blur(25px);
            border: 1px solid rgba(255, 255, 255, 0.05);
        }
    </style>
</head>
<body class="min-h-screen font-sans text-white flex items-center justify-center p-6">

<div class="glass p-10 rounded-[2rem] shadow-2xl max-w-4xl w-full">

    <!-- Header -->
    <div class="flex justify-between items-center border-b border-white/10 pb-6 mb-6">
        <h1 class="text-3xl font-bold">Welcome, <%= user.name %> 👋</h1>
        <span class="px-4 py-1 rounded-full text-sm font-semibold <%= user.isVerified ? 'bg-green-900/40 text-green-400' : 'bg-yellow-900/40 text-yellow-400' %>">
            <%= user.isVerified ? 'Verified Account' : 'Pending Verification' %>
        </span>
    </div>

    <!-- Profile Section -->
    <div class="flex flex-col md:flex-row gap-8">
        <div class="flex flex-col items-center">
            <img src="<%= user.profilePic || 'https://via.placeholder.com/150' %>"
                 class="w-40 h-40 rounded-full object-cover border-4 border-blue-500 shadow-lg">
            <p class="mt-4 text-slate-400 text-sm">Member since <%= new Date(user.createdAt).toLocaleDateString() %></p>
        </div>

        <div class="flex-1 space-y-3">
            <h2 class="text-2xl font-semibold mb-2">Profile Details</h2>

            <p><span class="text-slate-400">Email:</span> <%= user.email %></p>
            <p><span class="text-slate-400">Bio:</span> <%= user.bio || 'No bio added' %></p>
            <p><span class="text-slate-400">City:</span> <%= user.city || 'Not specified' %></p>
            <p><span class="text-slate-400">Education:</span> <%= user.education || 'Not specified' %></p>
            <p><span class="text-slate-400">Role:</span> <%= user.role %></p>
        </div>
    </div>

    <!-- Actions -->
    <div class="flex gap-4 mt-8">
        <a href="/secure/edit-user"
           class="flex-1 text-center bg-blue-600 hover:bg-blue-500 transition-all py-3 rounded-xl font-semibold shadow-lg">
            Edit Profile
        </a>

        <a href="/auth/logout"
           class="flex-1 text-center bg-red-600 hover:bg-red-500 transition-all py-3 rounded-xl font-semibold shadow-lg">
            Logout
        </a>
    </div>

    <!-- Audit Activity -->
    <div class="mt-10">
        <h2 class="text-2xl font-semibold mb-4">Audit Activity</h2>

        <div class="space-y-3 max-h-60 overflow-y-auto pr-2">
            <% if (audits && audits.length > 0) { %>
                <% audits.forEach(audit => { %>
                    <div class="bg-white/5 border border-white/10 p-4 rounded-xl">
                        <p><span class="text-slate-400">Action:</span> <%= audit.action %></p>
                        <p><span class="text-slate-400">IP:</span> <%= audit.ip %></p>
                        <p><span class="text-slate-400">Route:</span> <%= audit.route %></p>
                        <p><span class="text-slate-400">Time:</span> <%= new Date(audit.createdAt).toLocaleString() %></p>
                    </div>
                <% }) %>
            <% } else { %>
                <p class="text-slate-400">No activity found.</p>
            <% } %>
        </div>
    </div>

</div>

</body>
</html>
